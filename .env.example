# =============================================================================
# pgweb - Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values. Never commit your .env file.
#
# Required variables are marked with [REQUIRED]. Optional variables have defaults.

# --- Session Security [REQUIRED] ---
# A long, random string used to encrypt session cookies.
# Generate one with: openssl rand -base64 32
SESSION_SECRET_KEY=

# --- Application Database [REQUIRED] ---
# PostgreSQL DSN for the backend's own metadata (users, database records, jobs).
APP_DB_DSN=postgres://user:password@postgres:5432/app_db?sslmode=disable

# --- PostgreSQL Admin Connection [REQUIRED] ---
# DSN with superuser privileges for provisioning databases and users.
PG_ADMIN_DSN=postgres://admin_user:admin_password@postgres:5432/admin_db?sslmode=disable

# --- OIDC Authentication [REQUIRED] ---
OIDC_ISSUER_URL=http://dex:5556/dex
OIDC_CLIENT_ID=pgweb-frontend
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback

# --- Trusted Header Authentication ---
# Header used for trusted-header auth (set by reverse proxy like oauth2-proxy).
PGWEB_TRUSTED_HEADER=X-Forwarded-Email

# --- Frontend ---
# Path to the built frontend assets served by the backend.
FRONTEND_DIST=/app/frontend/dist
# Base URL of the frontend for redirects.
FRONTEND_BASE_URL=http://localhost:5173

# --- Backup Directory ---
# Directory where database dump files are stored temporarily.
BACKUP_DIR=/tmp/pgweb-backups

# --- Gin Framework ---
# "debug", "release", or "test"
GIN_MODE=debug
PORT=8080

# --- Connection Pool Tuning (optional) ---
# APP_DB_MAX_OPEN=25
# APP_DB_MAX_IDLE=25
# APP_DB_CONN_MAX_LIFETIME_MINUTES=5

# --- SSL Mode (optional, used by lib/pq if DSN doesn't specify) ---
# PGSSLMODE=require
